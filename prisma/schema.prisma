// =====================================================================
// Zero-Knowledge Password Manager — Prisma Schema (simplified)
// =====================================================================
// El servidor actúa como "crypto-blind store": SOLO almacena blobs
// cifrados, sales, IVs y llaves públicas. Nunca recibe ni almacena
// llaves maestras, llaves privadas en claro, ni claves simétricas.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

// Para producción con PostgreSQL, cambiar provider a "postgresql":
//   provider = "postgresql"
// Y configurar DATABASE_URL en el formato:
//   postgresql://user:password@host:5432/dbname?schema=public
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// Usuario: solo metadatos. La contraseña NUNCA se almacena.
// ---------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keyMaterial     UserKeyMaterial?
  ownedSecrets    Secret[]
  secretKeyShares SecretKeyShare[]
  devices         Device[]
  auditLogs       AuditLog[]
}

// ---------------------------------------------------------------------
// Multi-Device Sync (ECDH P-256)
// ---------------------------------------------------------------------
// Cada dispositivo autorizado tiene su propio par ECDH (P-256). La
// privateKey RSA del usuario se envuelve (wrap) con una llave simétrica
// derivada vía ECDH entre la publicKey ECDH del dispositivo y una
// privateKey ECDH efímera del dispositivo que autoriza.
// ---------------------------------------------------------------------
model Device {
  id                            String   @id @default(cuid())
  userId                        String
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName                    String
  publicKeyECDH                 String
  publicKeyECDHFingerprint      String
  enrollerPublicKeyECDH         String?
  wrappedPrivateKeyForDevice    String
  wrappedPrivateKeyIv           String
  enrollCode                    String?
  enrollCodeExpiresAt           DateTime?
  enrolledAt                    DateTime @default(now())
  lastSeenAt                    DateTime @default(now())
  revokedAt                     DateTime?

  @@index([userId])
  @@index([enrollCode])
}

// ---------------------------------------------------------------------
// Material criptográfico del usuario.
// - kdfSalt: SAL en claro (base64). Pública.
// - kdfIterations: int. Público.
// - publicKeyJwk: JSON en claro. Llave pública RSA-OAEP.
// - encryptedPrivateKeyJwk: BLOB cifrado (AES-256-GCM) con la llave
//   maestra derivada del password del usuario.
// ---------------------------------------------------------------------
model UserKeyMaterial {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kdfAlgorithm           String   @default("argon2id")
  kdfSalt                String
  kdfIterations          Int
  kdfMemoryKiB           Int?
  kdfParallelism         Int?
  publicKeyJwk           String
  publicKeyFingerprint   String
  popSignature           String
  popSignatureHash       String
  encryptedPrivateKeyJwk String
  privateKeyIv           String
  mlKemPublicKey         String?
  encryptedMlKemPrivateKey String?
  mlKemPrivateKeyIv      String?

  // Recovery Key (BIP-39) — backup cifrado de la privateKey RSA
  recoverySalt           String?
  recoveryIterations     Int?
  encryptedPrivateKeyForRecovery String?
  recoveryIv             String?
  recoveryEnabled        Boolean  @default(false)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([publicKeyFingerprint])
}

// ---------------------------------------------------------------------
// Secreto: contenido cifrado con AES-256-GCM.
// - El título TAMBIÉN va cifrado (Zero-Knowledge estricto).
// ---------------------------------------------------------------------
model Secret {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  encryptedTitle String
  titleIv        String
  encryptedData  String
  dataIv         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  keyShares SecretKeyShare[]

  @@index([ownerId, createdAt])
}

// ---------------------------------------------------------------------
// Share: la clave simétrica AES que desencripta el secreto, "envuelta"
// (wrapped) con la llave PÚBLICA RSA-OAEP del destinatario.
// ---------------------------------------------------------------------
model SecretKeyShare {
  id                  String   @id @default(cuid())
  secretId            String
  secret              Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  recipientId         String
  recipient           User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  wrappedSymmetricKey String
  role                String   @default("readonly")
  seenAt              DateTime?
  createdAt           DateTime @default(now())

  @@unique([secretId, recipientId])
}

// ---------------------------------------------------------------------
// Audit Log cifrado (Zero-Knowledge Logging) con hash chaining.
// ---------------------------------------------------------------------
model AuditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedEvent  String
  eventIv         String
  encryptedCategory String @default("")
  categoryIv      String   @default("")
  eventCategory   String
  prevHash        String?
  logHash         String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventCategory])
}
