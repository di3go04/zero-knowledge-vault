// =====================================================================
// Zero-Knowledge Password Manager — Prisma Schema
// =====================================================================
// El servidor actúa como "crypto-blind store": SOLO almacena blobs
// cifrados, sales, IVs y llaves públicas. Nunca recibe ni almacena
// llaves maestras, llaves privadas en claro, ni claves simétricas.
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Cambiar a "postgresql" para producción con PostgreSQL
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// Usuario: solo metadatos. La contraseña NUNCA se almacena.
// ---------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keyMaterial            UserKeyMaterial?
  ownedSecrets           Secret[]
  secretKeyShares        SecretKeyShare[]
  devices                Device[]
  auditLogs              AuditLog[]
  webAuthnCredentials    WebAuthnCredential[]
  emergencyGrants        EmergencyAccess[]    @relation("EmergencyGrantor")
  emergencyBeneficiaries EmergencyAccess[]    @relation("EmergencyBeneficiary")
  scimUser               ScimUser?
  userRoles              UserRole[]
  groupMemberships       GroupMember[]
  approvalRequests       ApprovalRequest[]    @relation("ApprovalRequester")
  approvalApprovals      ApprovalRequest[]    @relation("ApprovalApprover")
  breakGlassAccesses     BreakGlassAccess[]   @relation("BreakGlassRequester")
  breakGlassApprovals    BreakGlassAccess[]   @relation("BreakGlassApprover")
  complianceReports      ComplianceReport[]
  eDiscoveryExports      EDiscoveryExport[]
  actionTokens           UserActionToken[]
  accessRequests         AccessRequest[]
}

// ---------------------------------------------------------------------
// Multi-Device Sync (ECDH)
// ---------------------------------------------------------------------
// Cada dispositivo autorizado tiene su propio par ECDH (P-256). La
// privateKey RSA del usuario se envuelve (wrap) con una llave simétrica
// derivada vía ECDH entre la publicKey ECDH del dispositivo y una
// privateKey ECDH efímera del dispositivo que autoriza.
//
// Flujo "Enroll Device":
//   1. Dispositivo B genera par ECDH, muestra código + publicKeyECDH.
//   2. Dispositivo A (logueado) escanea, deriva ECDH shared secret,
//      envuelve la privateKey RSA del usuario con ese shared secret.
//   3. Servidor almacena el blob en Device.wrappedPrivateKeyForDevice.
//   4. Dispositivo B hace polling, recibe el blob, desenvuelve con su
//      privateKey ECDH, obtiene la privateKey RSA del usuario.
//
// El servidor NUNCA ve la privateKey RSA en claro ni el shared secret
// ECDH (que solo existe en los dos dispositivos).
// ---------------------------------------------------------------------
model Device {
  id                         String    @id @default(cuid())
  userId                     String
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName                 String
  // Llave pública ECDH P-256 del dispositivo NUEVO (B) — JWK, en claro
  publicKeyECDH              String // JSON
  publicKeyECDHFingerprint   String // hex SHA-256 del JWK canonizado
  // Post-Quantum: Llave pública Kyber ML-KEM 768 del dispositivo B (base64)
  publicKeyKyber             String? // base64, null si no soporta PQ
  // Ciphertext Kyber generado por dispositivo A para que B pueda decapsular
  kyberCiphertext            String? // base64, null hasta que A completa
  // Llave pública ECDH P-256 EFÍMERA del dispositivo AUTORIZADOR (A) — JWK
  // Se guarda cuando A completa el enrollment, para que B pueda derivar
  // el shared secret ECDH y desenvolver la wrappedPrivateKey.
  enrollerPublicKeyECDH      String? // JSON, null hasta que A completa
  // PrivateKey RSA del usuario, envuelta con la llave simétrica derivada
  // vía ECDH entre este dispositivo y el dispositivo que lo autorizó.
  // Si el envío es híbrido, la llave AES deriva de ECDH + Kyber combinados.
  wrappedPrivateKeyForDevice String // base64, AES-256-GCM
  wrappedPrivateKeyIv        String // base64, 12 bytes
  // Algoritmo usado: "ecdh" (clásico) o "hybrid-ecdh-kyber768" (post-quántico)
  keyExchangeAlgorithm       String    @default("hybrid-ecdh-kyber768")
  enrollCode                 String? // código de 6 dígitos (solo durante enrollment)
  enrollCodeExpiresAt        DateTime?
  enrolledAt                 DateTime  @default(now())
  lastSeenAt                 DateTime  @default(now())
  revokedAt                  DateTime? // null = activo

  @@index([userId])
  @@index([enrollCode])
}

// ---------------------------------------------------------------------
// Material criptográfico del usuario.
// - kdfSalt: SAL en claro (base64). Pública. Necesaria para PBKDF2.
// - kdfIterations: int. Público.
// - publicKeyJwk: JSON en claro. Llave pública RSA-OAEP.
// - encryptedPrivateKeyJwk: BLOB cifrado (AES-256-GCM) con la llave
//   maestra derivada del password del usuario. El servidor NO puede
//   descifrar esto.
// - privateKeyIv: IV en claro (base64) usado para cifrar la llave privada.
// ---------------------------------------------------------------------
model UserKeyMaterial {
  id                     String @id @default(cuid())
  userId                 String @unique
  user                   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // KDF — Argon2id (preferido) o PBKDF2 (legacy)
  kdfAlgorithm           String @default("argon2id") // "argon2id" | "pbkdf2"
  kdfSalt                String // base64, público
  kdfIterations          Int // Argon2id: t (time). PBKDF2: iteraciones.
  kdfMemoryKiB           Int? // Argon2id: m (memory). PBKDF2: null.
  kdfParallelism         Int? // Argon2id: p (parallelism). PBKDF2: null.
  publicKeyJwk           String // JSON string, público
  publicKeyFingerprint   String // hex SHA-256 del JWK canonizado — para TOFU y detección de sustitución
  popSignature           String // base64 — firma RSA-PSS de {email, publicKeyFingerprint, kdfSalt} con la privateKey
  popSignatureHash       String // "SHA-256" — algoritmo usado para la firma PoP (auditabilidad)
  encryptedPrivateKeyJwk String // base64, AES-256-GCM ciphertext con masterKey
  privateKeyIv           String // base64, público

  // Recovery Key (BIP-39) — backup cifrado de la privateKey RSA
  // El usuario recibe 24 palabras en el registro. Estas se derivan a
  // una llave AES-256 que cifra la MISMA privateKey RSA. Si el usuario
  // olvida su contraseña maestra, puede usar la frase de 24 palabras
  // para descifrar este blob y recuperar su cuenta.
  // El servidor NUNCA ve las 24 palabras — solo el blob cifrado.
  recoverySalt                   String? // base64, salt para derivar recovery key
  recoveryIterations             Int? // PBKDF2 iteraciones para recovery key (puede ser alto, no bloquea UI)
  encryptedPrivateKeyForRecovery String? // base64, AES-256-GCM con recovery key
  recoveryIv                     String? // base64, 12 bytes
  recoveryEnabled                Boolean @default(false)

  // Master key rotation: cada 30 días el usuario debe rotar su contraseña
  // maestra para limitar el daño si una masterKey fue comprometida.
  lastKeyRotationAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publicKeyFingerprint])
}

// ---------------------------------------------------------------------
// Emergency Access / Herencia Digital
// ---------------------------------------------------------------------
// Permite a un usuario designar herederos que pueden recuperar el acceso
// a su bóveda tras un periodo de inactividad o con time-lock + aprobación.
//
// Flujo:
//   1. Owner crea un grant: especifica beneficiary, delayHours, message.
//   2. Beneficiary reclama el grant → se inicia el time-lock.
//   3. Durante el time-lock, el owner puede cancelar.
//   4. Pasado el time-lock, el beneficiary puede recuperar la bóveda.
//      El servidor entrega el encryptedPrivateKeyForRecovery (si existe)
//      o el wrappedPrivateKey de un dispositivo.
// ---------------------------------------------------------------------
model EmergencyAccess {
  id            String    @id @default(cuid())
  grantorId     String
  grantor       User      @relation("EmergencyGrantor", fields: [grantorId], references: [id], onDelete: Cascade)
  beneficiaryId String
  beneficiary   User      @relation("EmergencyBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  message       String? // Mensaje del grantor al beneficiary
  delayHours    Int       @default(72) // 72h por defecto
  // Estados: "pending" → "active" (time-lock started) → "approved" (reclamado) → "cancelled"
  status        String    @default("pending") // pending | active | cancelled | completed
  claimedAt     DateTime? // Cuando el beneficiary inició el reclamo
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([grantorId, beneficiaryId])
  @@index([beneficiaryId])
}

// ---------------------------------------------------------------------
// Password Policies — configurables por organización
// ---------------------------------------------------------------------
model PasswordPolicy {
  id                String   @id @default(cuid())
  name              String   @default("default")
  minLength         Int      @default(12)
  maxLength         Int      @default(128)
  requireUppercase  Boolean  @default(true)
  requireLowercase  Boolean  @default(true)
  requireNumbers    Boolean  @default(true)
  requireSymbols    Boolean  @default(true)
  expirationDays    Int      @default(90)
  minUniqueChars    Int      @default(6)
  historySize       Int      @default(5) // No repetir últimas N contraseñas
  maxFailedAttempts Int      @default(5)
  lockoutMinutes    Int      @default(15)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ---------------------------------------------------------------------
// WebAuthn (FIDO2 / Passkeys) — autenticación sin contraseña
// ---------------------------------------------------------------------
// Soporta tanto hardware tokens (YubiKey) como authenticators de
// plataforma (Touch ID, Windows Hello, Face ID, passkeys).
// Cada credencial pertenece a un usuario y se usa como 2FA o como
// método de login sin contraseña.
// ---------------------------------------------------------------------
model WebAuthnCredential {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId   String   @unique
  publicKey      String // base64, llave pública cose
  counter        BigInt   @default(0)
  transports     String // JSON array: ["usb", "nfc", "ble", "internal"]
  deviceName     String? // Etiqueta: "YubiKey 5C NFC", "iPhone Passkey"
  credentialType String   @default("platform") // "platform" = passkey, "cross-platform" = YubiKey
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------
// Secreto: contenido cifrado con AES-256-GCM.
// - El título TAMBIÉN va cifrado (Zero-Knowledge estricto).
// - encryptedData / encryptedTitle: blobs AES-256-GCM.
// - El servidor no conoce ni el título ni el contenido.
// ---------------------------------------------------------------------
model Secret {
  id                String   @id @default(cuid())
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  encryptedTitle    String // base64, AES-256-GCM
  titleIv           String // base64
  encryptedData     String // base64, AES-256-GCM
  dataIv            String // base64
  encryptedMetadata String? // base64, AES-256-GCM — tags, URLs, notes cifrados
  metadataIv        String? // base64
  secretType        String   @default("password") // password | note | ssh-key | api-key | certificate | database
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  keyShares SecretKeyShare[]
}

// ---------------------------------------------------------------------
// Share: la clave simétrica AES que desencripta el secreto, "envuelta"
// (wrapped) con la llave PÚBLICA RSA-OAEP del destinatario.
// - Solo el destinatario puede desenvolverla con su llave privada.
// - El servidor nunca ve la clave simétrica en claro.
// - El propietario del secreto también tiene un share para sí mismo.
// ---------------------------------------------------------------------
model SecretKeyShare {
  id                  String   @id @default(cuid())
  secretId            String
  secret              Secret   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  recipientId         String
  recipient           User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  wrappedSymmetricKey String // base64, RSA-OAEP(AES key)
  createdAt           DateTime @default(now())

  @@unique([secretId, recipientId])
}

// ---------------------------------------------------------------------
// Audit Log cifrado (Zero-Knowledge Logging)
// ---------------------------------------------------------------------
// Los logs se generan y CIFRAN en el cliente (AES-256-GCM con una llave
// de auditoría derivada de la masterKey del usuario). El servidor solo
// almacena blobs cifrados + metadata mínima (timestamp, tipo de evento
// cifrado). Esto permite auditoría forense sin filtrar información
// sensible en logs del servidor.
//
// La llave de auditoría es distinta de la masterKey para evitar que un
// atacante con la masterKey (ej. via sesión abierta) pueda leer los logs
// históricos. Se deriva como HKDF(masterKey, "audit-log-v1").
// ---------------------------------------------------------------------
model AuditLog {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedEvent    String // base64, AES-256-GCM
  eventIv           String // base64, 12 bytes
  eventCategory     String // "auth" | "secret" | "share" | "rotation" | "device"
  // Hash chain: SHA-256 del encryptedEvent del log anterior del mismo usuario.
  // Crea una cadena inmutable: alterar un log requiere recalcular todos los
  // hashes siguientes. El primer log de un usuario tiene previousHash="".
  previousEventHash String   @default("")
  // HMAC-SHA256 del encryptedEvent usando la auditKey derivada (se verifica
  // en el cliente al descifrar). Sirve como prueba de integridad adicional.
  eventSignature    String   @default("")
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventCategory])
  @@index([previousEventHash])
}

// ---------------------------------------------------------------------
// Enterprise Feature Models (#21–#30)
// ---------------------------------------------------------------------

// #21 — SCIM 2.0 Provisioning
model ScimUser {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalId String   @unique
  userName   String   @unique
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([externalId])
  @@index([userName])
}

// #22 — SAML 2.0 / OIDC SSO Provider
model SsoProvider {
  id               String   @id @default(cuid())
  providerType     String // "saml" | "oidc"
  providerName     String   @unique
  issuerUrl        String
  clientId         String?
  clientSecret     String?
  metadataUrl      String?
  metadataXml      String?
  attributeMapping String? // JSON
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// #23 — LDAP / Active Directory Connector
model DirectoryConnector {
  id                String    @id @default(cuid())
  name              String    @unique
  providerType      String // "ldap" | "active-directory"
  url               String
  baseDn            String
  bindDn            String
  bindPassword      String // encrypted at rest
  userSearchFilter  String    @default("(objectClass=person)")
  groupSearchFilter String    @default("(objectClass=group)")
  syncIntervalSec   Int       @default(3600)
  enabled           Boolean   @default(true)
  lastSyncAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// #24 — RBAC Granular
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions         Permission[]
  userRoles           UserRole[]
  scopes              RoleScope[]
  permissionOverrides RolePermissionOverride[]
}

model Permission {
  id         String   @id @default(cuid())
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  action     String
  resource   String
  conditions String? // JSON — future ABAC conditions
  createdAt  DateTime @default(now())

  @@unique([roleId, action, resource])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy String?
  createdAt  DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// #25 — Group Policies
model UserGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  GroupMember[]
  policies GroupPolicy[]
}

model GroupMember {
  id        String    @id @default(cuid())
  groupId   String
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String    @default("member") // "member" | "admin"
  createdAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupPolicy {
  id          String    @id @default(cuid())
  groupId     String
  group       UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  policyType  String // "password" | "session" | "mfa" | "sharing"
  policyValue String // JSON
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([groupId, policyType])
  @@index([groupId])
}

// #26 — Approval Workflows
model ApprovalRequest {
  id              String    @id @default(cuid())
  requesterId     String
  requester       User      @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  action          String // "share" | "export" | "emergency-access" | "admin-action"
  resourceType    String // "secret" | "vault" | "setting"
  resourceId      String?
  reason          String
  status          String    @default("pending") // "pending" | "approved" | "rejected" | "cancelled"
  approvedById    String?
  approvedBy      User?     @relation("ApprovalApprover", fields: [approvedById], references: [id])
  approverComment String?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([requesterId])
  @@index([status])
}

// #27 — Dual Control / Break-Glass
model BreakGlassAccess {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("BreakGlassRequester", fields: [userId], references: [id], onDelete: Cascade)
  reason      String
  status      String    @default("pending") // "pending" | "approved" | "denied" | "expired"
  approverId  String?
  approver    User?     @relation("BreakGlassApprover", fields: [approverId], references: [id])
  approvedAt  DateTime?
  expiresAt   DateTime?
  accessToken String? // HMAC token temporal
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// #28 — Webhooks for SIEM
model WebhookConfig {
  id              String    @id @default(cuid())
  name            String
  url             String
  secret          String? // HMAC secret for payload signing
  events          String // JSON array — ["auth:login", "secret:read", ...]
  enabled         Boolean   @default(true)
  retryCount      Int       @default(3)
  timeoutMs       Int       @default(5000)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// #30 — Compliance Reports
model ComplianceReport {
  id            String    @id @default(cuid())
  reportType    String // "soc2" | "hipaa" | "gdpr" | "custom" | "admin-audit"
  periodStart   DateTime
  periodEnd     DateTime
  status        String    @default("pending") // "pending" | "generating" | "completed" | "failed"
  parameters    String? // JSON
  resultData    String? // JSON
  generatedById String?
  generatedBy   User?     @relation(fields: [generatedById], references: [id])
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([reportType])
  @@index([status])
}

// =====================================================================
// Enterprise Feature Models (#31–#40)
// =====================================================================

// #31 — eDiscovery / Forensic Export
model EDiscoveryExport {
  id            String    @id @default(cuid())
  requestedById String
  targetUserId  String
  requestedBy   User      @relation(fields: [requestedById], references: [id])
  reason        String
  dataTypes     String // JSON array
  status        String    @default("pending") // "pending" | "completed" | "failed"
  exportData    String? // JSON
  expiresAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([targetUserId])
  @@index([requestedById])
  @@index([status])
}

// #32 — DLP (Data Loss Prevention)
model DlpRule {
  id           String   @id @default(cuid())
  name         String
  description  String?
  pattern      String
  action       String // "block" | "alert" | "mask" | "audit"
  resourceType String   @default("all") // "secret" | "note" | "all"
  severity     String   @default("medium") // "low" | "medium" | "high" | "critical"
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scanResults DlpScanResult[]
}

model DlpScanResult {
  id              String   @id @default(cuid())
  ruleId          String
  rule            DlpRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  resourceType    String
  resourceId      String
  detectedContent String?
  action          String
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([ruleId])
  @@index([resourceType, resourceId])
}

// #33 — Retention Policies
model RetentionPolicy {
  id            String   @id @default(cuid())
  name          String
  description   String?
  resourceType  String // "audit-log" | "secret" | "session" | "export"
  retentionDays Int
  action        String   @default("delete") // "delete" | "archive" | "anonymize"
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// #34 — Custom Roles (extending #24 RBAC)
model RoleScope {
  id         String   @id @default(cuid())
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeType  String // "global" | "group" | "vault"
  scopeValue String?
  createdAt  DateTime @default(now())

  @@unique([roleId, scopeType, scopeValue])
  @@index([roleId])
}

model RolePermissionOverride {
  id            String   @id @default(cuid())
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionKey String // "admin-panel" | "export" | "manage-users" | "manage-policies"
  granted       Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([roleId, permissionKey])
  @@index([roleId])
}

// #35 — Directory Sync (cloud directories)
model DirectorySyncConfig {
  id              String    @id @default(cuid())
  provider        String // "azure-ad" | "google-workspace" | "okta" | "onelogin"
  name            String
  clientId        String
  clientSecret    String
  tenantId        String?
  domain          String?
  syncIntervalSec Int       @default(3600)
  enabled         Boolean   @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  syncLogs DirectorySyncLog[]
}

model DirectorySyncLog {
  id               String              @id @default(cuid())
  configId         String
  config           DirectorySyncConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  status           String // "success" | "partial" | "failed"
  usersCreated     Int                 @default(0)
  usersUpdated     Int                 @default(0)
  usersDeactivated Int                 @default(0)
  groupsSynced     Int                 @default(0)
  errorMessage     String?
  startedAt        DateTime
  completedAt      DateTime?
  createdAt        DateTime            @default(now())

  @@index([configId])
  @@index([status])
}

// #36 — SLA Monitoring
model UptimeMonitor {
  id             String   @id @default(cuid())
  name           String
  endpoint       String
  method         String   @default("GET")
  expectedStatus Int      @default(200)
  intervalSec    Int      @default(300)
  timeoutMs      Int      @default(10000)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  healthChecks HealthCheckLog[]
}

model HealthCheckLog {
  id             String        @id @default(cuid())
  monitorId      String
  monitor        UptimeMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status         String // "up" | "down" | "degraded"
  statusCode     Int?
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime      @default(now())

  @@index([monitorId, checkedAt])
  @@index([status])
}

// #37 — Multitenant
model Tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  domain     String?  @unique
  plan       String   @default("enterprise") // "starter" | "business" | "enterprise"
  status     String   @default("active") // "active" | "suspended" | "cancelled"
  maxUsers   Int      @default(100)
  maxSecrets Int      @default(1000)
  features   String? // JSON — feature flags
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branding TenantBranding?
}

// #38 — Tenant Branding
model TenantBranding {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String   @default("#2563eb")
  secondaryColor String?  @default("#1e40af")
  accentColor    String?  @default("#10b981")
  companyName    String?
  supportUrl     String?
  supportEmail   String?
  customCss      String?
  loginMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// #39 — Admin API Keys
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyPrefix   String
  keyHash     String    @unique
  permissions String // JSON array
  createdById String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyPrefix])
}

// #40 — Self-Service Portal / User Action Tokens
model UserActionToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  action    String // "email-verify" | "password-reset" | "device-approve" | "recovery-enable" | "account-recover"
  payload   String? // JSON
  status    String    @default("pending") // "pending" | "used" | "expired" | "revoked"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, action])
  @@index([token])
  @@index([status, expiresAt])
}

// =====================================================================
// Collaboration Feature Models (#41–#52)
// =====================================================================

// #41 — One-Time Share
// Crea un link de un solo uso (o N usos máx) para compartir un secreto.
// El token es un identificador opaco; al canjearlo, el servidor entrega
// la wrappedSymmetricKey y marca el uso. Una vez alcanzado maxViews, se
// invalida.
model OneTimeShare {
  id                  String    @id @default(cuid())
  secretId            String
  ownerId             String
  token               String    @unique
  wrappedSymmetricKey String
  maxViews            Int       @default(1)
  currentViews        Int       @default(0)
  expiresAt           DateTime
  status              String    @default("active") // active | claimed | expired
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([token])
  @@index([ownerId])
  @@index([status, expiresAt])
}

// #42 — Temporary Vault
// Vault efímero que expira automáticamente. Pensado para integraciones
// temporales o equipos externos con acceso limitado en el tiempo.
model TempVault {
  id            String    @id @default(cuid())
  ownerId       String
  name          String?
  encryptedData String? // base64 — el contenido cifrado del vault temporal
  dataIv        String?
  expiresAt     DateTime
  status        String    @default("active") // active | expired
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerId])
  @@index([status, expiresAt])
}

// #43 — Secret Version History
// Cada versión almacena una foto completa del secreto (cifrado) en ese
// momento. encryptedDiff (opcional) es un diff cifrado que el cliente
// puede calcular para mostrar cambios. El servidor nunca ve el contenido.
model SecretVersion {
  id              String   @id @default(cuid())
  secretId        String
  versionNumber   Int
  encryptedData   String // base64 — AES-256-GCM
  dataIv          String // base64
  encryptedTitle  String? // base64 — puede cambiar entre versiones
  titleIv         String?
  encryptedDiff   String? // base64 — diff cifrado opcional
  diffIv          String?
  createdBy       String   // userId
  changelog       String? // metadata: "Rotación de contraseña", "Actualización de URL", etc.
  createdAt       DateTime @default(now())

  @@unique([secretId, versionNumber])
  @@index([secretId, createdAt])
}

// #44 — Comment / Annotation
// Comentarios sobre un secreto. El contenido puede ir cifrado o en
// claro (depende del policy). mentions (JSON array) almacena los
// userIds mencionados con @ para notificaciones.
model Comment {
  id        String   @id @default(cuid())
  secretId  String
  authorId  String
  content   String // puede ir cifrado (base64 AES-GCM) si el policy lo exige
  contentIv String? // IV si content está cifrado
  mentions  String? // JSON array: ["userId1", "userId2"]
  parentId  String? // ID del comentario padre (para replies en hilo)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([secretId, createdAt])
  @@index([authorId])
}

// #45 — Notification
// Notificaciones push/SSE para eventos en tiempo real.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // "share" | "comment" | "access-request" | "approval" | "system"
  title     String
  body      String?
  data      String? // JSON payload
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// #46 — Activity Event
// Feed de actividad del usuario: acciones realizadas sobre recursos.
model ActivityEvent {
  id           String   @id @default(cuid())
  userId       String
  action       String // "create" | "share" | "view" | "edit" | "delete" | "comment" | "import" | "export"
  resourceType String // "secret" | "vault" | "share" | "comment"
  resourceId   String?
  metadata     String? // JSON — detalles adicionales
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([resourceType, resourceId])
}

// #47 — Pre-Approval Sharing
// Flujo: Alice solicita aprobación para compartir con Bob, un approver
// (ej. manager) aprueba o rechaza. Si aprueba, la wrappedSymmetricKey
// se entrega al destinatario.
model ShareApproval {
  id                  String    @id @default(cuid())
  secretId            String
  requesterId         String
  approverId          String
  recipientId         String?
  reason              String?
  status              String    @default("pending") // pending | approved | rejected | cancelled
  wrappedSymmetricKey String? // se asigna al aprobar
  approverComment     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([secretId])
  @@index([approverId, status])
  @@index([requesterId])
}

// #48 — Tags & Favorites
// Tags para organizar y buscar secretos. Relación N:M entre Secret y Tag.
model Tag {
  id           String      @id @default(cuid())
  name         String      @unique
  color        String?     @default("#6366f1")
  favorite     Boolean     @default(false) // si es un tag de favoritos o tag normal
  createdBy    String?
  createdAt    DateTime    @default(now())

  secretTags   SecretTag[]
}

model SecretTag {
  id        String   @id @default(cuid())
  secretId  String
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([secretId, tagId])
  @@index([secretId])
  @@index([tagId])
}

// #49 — Import/Export Log
// Registro de operaciones de importación/exportación de contraseñas.
model ImportExportLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // "import" | "export"
  source    String? // "bitwarden" | "1password" | "dashlane" | "lastpass" | "manual"
  format    String   @default("csv")
  itemCount Int      @default(0)
  status    String   @default("completed") // completed | failed
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// #50 — Email Share (Magic Link)
// Compartir un secreto vía email. El destinatario recibe un magic link
// con un token. Al abrirlo, si el destinatario tiene cuenta, puede
// reclamar el share. Si no, se le invita a registrarse.
model EmailShare {
  id                  String    @id @default(cuid())
  secretId            String
  senderId            String
  recipientEmail      String
  token               String    @unique
  wrappedSymmetricKey String? // se asigna cuando el destinatario reclama
  message             String? // mensaje opcional del remitente
  status              String    @default("pending") // pending | sent | claimed | expired
  expiresAt           DateTime
  claimedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([token])
  @@index([recipientEmail])
  @@index([senderId])
}

// #51 — Access Request
// Un usuario solicita acceso a un secreto que no le pertenece.
// El owner del secreto puede aprobar o denegar.
model AccessRequest {
  id              String    @id @default(cuid())
  secretId        String
  requesterId     String
  requester       User      @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  reason          String?
  status          String    @default("pending") // pending | approved | denied
  approverId      String?
  approverComment String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([secretId, status])
  @@index([requesterId, status])
}

// #52 — Share Audit Event
// Registro detallado de cada acción sobre shares: quién, qué, cuándo.
model ShareAuditEvent {
  id        String   @id @default(cuid())
  secretId  String
  actorId   String
  action    String // "share" | "revoke" | "view" | "claim" | "approve" | "deny" | "request" | "email-share"
  targetId  String? // userId del destinatario o email
  metadata  String? // JSON — detalles adicionales
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([secretId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}
