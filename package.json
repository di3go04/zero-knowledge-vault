{
  "name": "zk-vault",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build --webpack",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && prisma db push --accept-data-loss && next build --webpack",
    "start": "NODE_ENV=production bun .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "bun prisma/seed.ts",
    "audit:ci": "bun audit --production --severity moderate",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/post-quantum": "^0.6.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.20",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-toast": "^1.2.20",
    "@radix-ui/react-toggle": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@sentry/nextjs": "^10.67.0",
    "@zk-vault/crypto": "file:./packages/crypto",
    "bip39": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hash-wasm": "^4.12.0",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.525.0",
    "next": "^16.2.11",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.22",
    "prisma": "^6.19.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "secrets.js-grempe": "^2.0.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "lightningcss": "^1.33.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
