# =====================================================================
# Zero-Knowledge Vault — Variables de Entorno
# =====================================================================
# Copia este archivo a .env y ajusta los valores.
# En producción, usa secretos aleatorios seguros (openssl rand -base64 48).
# =====================================================================

# === Base de datos (OBLIGATORIO) ===
# SQLite para desarrollo, PostgreSQL para producción.
DATABASE_URL="file:./db/custom.db"
# Producción con PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/zk_vault?schema=public"

# === Sesión (OBLIGATORIO) ===
# Secreto para firmar tokens HS256. MÍNIMO 32 caracteres.
# Generar con: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-random-32-char-string-please!!"

# === Redis (OPCIONAL) ===
# Si está definido, se usa para:
#   - Blacklist de tokens revocados (logout server-side)
#   - Rate limiting distribuido
#   - Challenge store ECDSA (multi-instancia)
# Sin REDIS_URL, usa Map in-memory (single-process, dev only).
# REDIS_URL="redis://localhost:6379"

# === Decoy login (OPCIONAL) ===
# Clave HMAC para generar respuestas decoy deterministas en login de
# usuarios inexistentes (anti-enumeración).
# Generar con: openssl rand -base64 32
# DECOY_HMAC_KEY="change-me-to-a-random-32-char-string"

# === Logging (OPCIONAL) ===
# Nivel de log: debug | info | warn | error
# Por defecto: debug en desarrollo, info en producción.
# LOG_LEVEL="info"

# === Entorno ===
NODE_ENV="development"
# NODE_ENV="production"

# =====================================================================
# NOTAS DE SEGURIDAD
# =====================================================================
# 1. SESSION_SECRET debe ser ÚNICO por entorno y nunca commiteado.
# 2. En producción, usa PostgreSQL (no SQLite) para concurrencia.
# 3. REDIS_URL es muy recomendado en producción multi-instancia.
# 4. Si usas un proxy (nginx, Caddy), configura trusted proxies para
#    que getClientIp() lea correctamente el header X-Forwarded-For.
# 5. El servidor nunca loggea secretos. Pino está configurado para
#    redactar: masterPassword, masterKey, privateKey, sessionToken, etc.
